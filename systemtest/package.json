{
  "name": "systemtest",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright system test suite for the BluLedger banking demo app.",
  "scripts": {
    "ensure:env": "node ./scripts/ensure-local-env.mjs",
    "test": "node ./scripts/ensure-local-env.mjs && playwright test",
    "test:smoke": "node ./scripts/ensure-local-env.mjs && playwright test --grep @smoke",
    "test:regression": "node ./scripts/ensure-local-env.mjs && playwright test --grep @regression",
    "test:critical": "node ./scripts/ensure-local-env.mjs && playwright test --grep @critical",
    "demo:ui": "node ./scripts/ensure-local-env.mjs && npm run dev --prefix .. -- --host 127.0.0.1 --port 5173",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "report:playwright": "playwright show-report reports/html",
    "report:allure": "node ./scripts/generate-allure-report.mjs",
    "report:allure:open": "allure open reports/allure",
    "ci": "bash ./scripts/run-tests.sh"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@eslint/js": "^9.12.0",
    "allure": "^3.3.1",
    "allure-playwright": "^3.6.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.2"
  }
}
